#####################
# Azure AKS Multi-Cluster Blueprint - Example Variables
#
# Copy this file to terraform.tfvars in the appropriate layer directory
# and update values for your environment.
#
# Aviatrix Controller credentials are passed via environment variables:
#   export AVIATRIX_CONTROLLER_IP="controller.example.com"
#   export AVIATRIX_USERNAME="admin"
#   export AVIATRIX_PASSWORD="your-password"
#
# Azure credentials are passed via az login or environment variables:
#   export ARM_CLIENT_ID="..."
#   export ARM_CLIENT_SECRET="..."
#   export ARM_SUBSCRIPTION_ID="..."
#   export ARM_TENANT_ID="..."
#####################

# Prefix for all resource names (enables multiple deployments in the same subscription)
name_prefix = "k8s-demo"

# Azure region
azure_region = "East US 2"

# Azure subscription ID
azure_subscription_id = "your-subscription-id-here"

# Aviatrix account name as registered in the Controller
aviatrix_azure_account_name = "azure-account"

# AKS node pool configuration
node_group_config = {
  min_count  = 1
  max_count  = 3
  node_count = 2
  vm_size    = "Standard_D4s_v3"
  priority   = "Spot"
}

# Azure Private DNS zone for internal service discovery
private_dns_zone_name = "azure.aviatrixdemo.local"

# Network CIDRs (override defaults if they conflict with existing infrastructure)
# transit_cidr      = "10.32.0.0/20"
# frontend_vnet_cidr = "10.30.0.0/20"
# backend_vnet_cidr  = "10.31.0.0/20"
# db_vnet_cidr       = "10.35.0.0/22"
# pod_cidr           = "100.64.0.0/16"
