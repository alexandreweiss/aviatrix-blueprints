# Aviatrix Control Plane Configuration
# Set these via environment variables (recommended):
# export AVIATRIX_CONTROLLER_IP="<controller-ip>"
# export AVIATRIX_USERNAME="<username>"
# export AVIATRIX_PASSWORD="<password>"

# Resource Naming
# All resources will be prefixed with this value (enables multiple deployments)
name_prefix = "k8s-demo"

# GCP Configuration
aviatrix_gcp_account_name = "your-gcp-account-name"  # GCP account name as registered in Aviatrix Controller
gcp_region                = "us-central1"
gcp_project               = "your-gcp-project-id"

# GKE Node Pool Configuration
node_pool_config = {
  min_node_count     = 1
  max_node_count     = 3
  initial_node_count = 1
  machine_type       = "e2-standard-4"
  spot               = true  # Use false for production
}

# DNS Configuration
dns_private_zone_name = "gcp.aviatrixdemo.local"

# Network CIDRs (defaults shown - override if these conflict with your environment)
# transit_cidr      = "10.42.0.0/20"
# frontend_vpc_cidr = "10.40.0.0/20"
# backend_vpc_cidr  = "10.41.0.0/20"
# db_vpc_cidr       = "10.45.0.0/22"
# pod_cidr          = "100.64.0.0/16"
# services_cidr     = "172.40.0.0/20"

# GKE Private Cluster Master CIDR (must be /28)
# master_ipv4_cidr_block = "172.16.0.0/28"
